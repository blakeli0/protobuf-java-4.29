digraph ProtobufFilteredRelationships {
  rankdir=BT;
  node [shape=box, style=filled, fillcolor=lightblue];
  "IntList" [fillcolor=lightgreen];
  "FloatArrayList" [fillcolor=lightblue];
  "BuilderParent" [fillcolor=lightgreen];
  "FileDescriptor" [fillcolor=lightblue];
  "ByteString" [fillcolor=lightblue];
  "FieldDescriptor" [fillcolor=lightblue];
  "DoubleArrayList" [fillcolor=lightblue];
  "LongArrayList" [fillcolor=lightblue];
  "IntArrayList" [fillcolor=lightblue];
  "Descriptor" [fillcolor=lightblue];
  "SourceContext" [fillcolor=lightblue];
  "EnumValueDescriptor" [fillcolor=lightblue];
  "FieldAccessorTable" [fillcolor=lightblue];
  "UnknownFieldSet" [fillcolor=lightblue];
  "CodedOutputStream" [fillcolor=lightblue];
  "ProtocolMessageEnum" [fillcolor=lightgreen];
  "Method" [fillcolor=lightblue];
  "SourceContextOrBuilder" [fillcolor=lightgreen];
  "Option" [fillcolor=lightblue];
  "Type" [fillcolor=lightblue];
  "MessageOrBuilder" [fillcolor=lightgreen];
  "BooleanArrayList" [fillcolor=lightblue];
  "InvalidProtocolBufferException" [fillcolor=lightblue];
  "Value" [fillcolor=lightblue];
  "EnumDescriptor" [fillcolor=lightblue];
  "Field" [fillcolor=lightblue];
  "MessageLite" [fillcolor=lightgreen];
  "GeneratedMessage" [fillcolor=lightblue];
  "UninitializedMessageException" [fillcolor=lightblue];
  "Builder" [fillcolor=lightblue];
  "AbstractMessage" [fillcolor=lightblue];
  "Parser" [fillcolor=lightblue];
  "LazyField" [fillcolor=lightblue];
  "ExtensionRegistry" [fillcolor=lightblue];
  "LazyStringList" [fillcolor=lightgreen];
  "Entry" [fillcolor=lightblue];
  "OneofDescriptor" [fillcolor=lightblue];
  "Message" [fillcolor=lightgreen];
  "OptionOrBuilder" [fillcolor=lightgreen];
  "Message" -> "MessageOrBuilder" [style=solid];
  "Builder" -> "MessageOrBuilder" [style=solid];
  "UnknownFieldSet" -> "MessageLite" [style=dashed];
  "Message" -> "MessageLite" [style=solid];
}
